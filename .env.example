# ============================================================
# ClassLog 환경변수 예시
# 이 파일을 .env.local 로 복사한 뒤 값을 채워주세요.
# 로컬 개발에서는 이 변수들 없이도 동작 (로컬 IndexedDB만 사용).
# ============================================================

# ----- 사용자 비밀번호 (로그인) -----
# 설정하면 앱 진입 시 비밀번호 입력 화면이 뜨고, 동기화 API가 활성화됩니다.
# 설정 안 하면 인증 없이 로컬 데이터만 사용 (개발용).
APP_PASSWORD=

# ----- Vercel Redis -----
# Vercel 대시보드 → Storage 탭 → Marketplace에서 Redis 추가 시
# 통합 방식에 따라 아래 셋 중 하나의 형태로 환경변수가 주입됩니다.
# 우리 코드는 셋 다 자동 인식합니다.
#
# (A) Vercel 신형 Redis 통합 — TCP 연결 문자열
#     REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379
REDIS_URL=
#
# (B) Upstash REST
#     UPSTASH_REDIS_REST_URL=
#     UPSTASH_REDIS_REST_TOKEN=
#
# (C) 구 Vercel KV (deprecated)
#     KV_REST_API_URL=
#     KV_REST_API_TOKEN=
