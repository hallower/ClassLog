# ============================================================
# ClassLog 환경변수 예시
# 이 파일을 .env.local 로 복사한 뒤 값을 채워주세요.
# 로컬 개발에서는 이 변수들 없이도 동작 (로컬 IndexedDB만 사용).
# ============================================================

# ----- 사용자 비밀번호 (로그인) -----
# 설정하면 앱 진입 시 비밀번호 입력 화면이 뜨고, 동기화 API가 활성화됩니다.
# 설정 안 하면 인증 없이 로컬 데이터만 사용 (개발용).
APP_PASSWORD=

# ----- Vercel Redis (Upstash) -----
# Vercel 대시보드 → Storage 탭 → Marketplace → Upstash Redis 추가 시
# UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN 두 변수가 자동 주입됩니다.
# (구 Vercel KV 방식인 KV_REST_API_URL / KV_REST_API_TOKEN 도 자동 인식)
# 로컬에서는 Upstash 대시보드에서 발급 후 입력.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
