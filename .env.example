# ============================================================
# ClassLog 환경변수 예시
# 이 파일을 .env.local 로 복사한 뒤 값을 채워주세요.
# .env.local 은 git에 커밋되지 않습니다.
# ============================================================

# Google Drive 동기화를 "구글로 로그인" 한 번에 끝내고 싶을 때 설정합니다.
# (생략하면 사용자가 직접 설정 화면에서 Client ID를 붙여넣는 흐름이 활성화됩니다.)
#
# 1) https://console.cloud.google.com/ 에서 프로젝트 생성
# 2) "API 및 서비스 → 사용자 인증 정보 → OAuth 클라이언트 ID(웹 애플리케이션)" 발급
# 3) 승인된 JavaScript 원본에 운영 도메인(예: https://classlog.vercel.app)과
#    개발 도메인(http://localhost:3000)을 모두 등록
# 4) "Google Drive API" 사용 설정 + OAuth 동의 화면에서 본인 이메일을 테스트 사용자로 등록
# 5) 발급받은 Client ID를 아래에 입력
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
